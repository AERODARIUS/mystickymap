rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function affectedKeys() {
      return incoming().diff(existing()).affectedKeys();
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================
    
    function isValidNote(data) {
      return data.keys().hasAll(['type', 'location', 'authorId', 'createdAt', 'authorName', 'content', 'privacy']) &&
             data.keys().size() <= 16 && 
             data.type in ['text', 'audio'] &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.location is map && data.location.lat is number && data.location.lng is number &&
             data.privacy is string && data.privacy in ['public', 'unlisted', 'private'] &&
             data.createdAt is timestamp &&
             (!('content' in data) || (data.content is string && data.content.size() <= 2000)) &&
             (!('audioUrl' in data) || (data.audioUrl is string && data.audioUrl.size() <= 500 && data.audioUrl.matches("^https://.*"))) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('color' in data) || (data.color is string && data.color.matches("^#[0-9a-fA-F]{6}$"))) &&
             (!('emoji' in data) || (data.emoji is string && data.emoji.size() <= 10)) &&
             (!('language' in data) || (data.language is string && data.language.size() <= 20)) &&
             (!('moderationState' in data) || (data.moderationState is string && data.moderationState in ['visible', 'pending_review', 'removed']));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName']) &&
             data.keys().size() <= 5 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('role' in data) || (data.role is string && data.role in ['user', 'admin'])) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidComment(data, noteId) {
      return data.keys().hasAll(['content', 'authorId', 'authorName', 'createdAt', 'noteId']) &&
             data.keys().size() == 5 &&
             data.content is string && data.content.size() <= 500 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.noteId is string && data.noteId == noteId &&
             data.createdAt is timestamp;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['noteId', 'reporterId', 'reason', 'createdAt', 'status']) &&
             data.keys().size() <= 6 &&
             data.noteId is string && data.noteId.size() <= 128 &&
             data.reporterId is string &&
             data.reason is string && data.reason in ['spam', 'harassment', 'hate_speech', 'nsfw', 'threat', 'other'] &&
             (!('details' in data) || (data.details is string && data.details.size() <= 1000)) &&
             data.createdAt is timestamp &&
             data.status is string && data.status in ['pending', 'resolved', 'dismissed'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /notes/{noteId} {
      allow get: if isValidId(noteId) && (
        (existing().privacy in ['public', 'unlisted'] && (!('moderationState' in existing()) || existing().moderationState == 'visible')) || 
        isOwner(existing().authorId) || 
        isAdmin()
      );
      allow list: if (
        (resource.data.privacy == 'public' && (!('moderationState' in resource.data) || resource.data.moderationState == 'visible')) || 
        (isSignedIn() && resource.data.authorId == request.auth.uid) ||
        isAdmin()
      );
      
      allow create: if isVerifiedUser() && 
                       isValidNote(incoming()) && 
                       incoming().createdAt == request.time &&
                       (!('moderationState' in incoming()) || incoming().moderationState == 'visible');
      
      allow update: if isVerifiedUser() && 
                       isValidId(noteId) &&
                       (isOwner(existing().authorId) || isAdmin()) && 
                       isValidNote(incoming()) &&
                       (isAdmin() || (
                         incoming().authorId == existing().authorId && 
                         incoming().createdAt == existing().createdAt && 
                         incoming().updatedAt == request.time &&
                         (!('moderationState' in incoming()) || incoming().moderationState == existing().moderationState) &&
                         affectedKeys().hasOnly(['content', 'audioUrl', 'location', 'updatedAt', 'color', 'emoji', 'language', 'authorName', 'privacy'])
                       ));
      
      allow delete: if isValidId(noteId) && (isOwner(existing().authorId) || isAdmin());

      match /comments/{commentId} {
        function getParentNote() {
          return get(/databases/$(database)/documents/notes/$(noteId)).data;
        }
        function canInteractWithNote() {
          let note = getParentNote();
          return (note.privacy in ['public', 'unlisted'] && (!('moderationState' in note) || note.moderationState == 'visible')) || isOwner(note.authorId) || isAdmin();
        }

        allow get: if isValidId(commentId) && canInteractWithNote();
        allow list: if canInteractWithNote();
        
        allow create: if isVerifiedUser() && 
                         isValidId(commentId) &&
                         isValidComment(incoming(), noteId) &&
                         incoming().createdAt == request.time &&
                         canInteractWithNote();
        
        allow delete: if isValidId(commentId) && (
          isOwner(existing().authorId) || 
          isOwner(getParentNote().authorId) ||
          isAdmin()
        );
      }
    }

    match /reports/{reportId} {
      allow get: if isValidId(reportId) && (isOwner(existing().reporterId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isValidId(reportId) &&
                       isValidReport(incoming()) &&
                       incoming().createdAt == request.time &&
                       incoming().status == 'pending' &&
                       (isSignedIn() || incoming().reporterId == 'anonymous');
      
      allow update: if isAdmin() && isValidReport(incoming());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAdmin(); 
      
      allow create: if isVerifiedUser() && isOwner(userId) && isValidUser(incoming());
      
      allow update: if isVerifiedUser() && 
                       isValidId(userId) && 
                       isOwner(userId) && 
                       isValidUser(incoming()) &&
                       (!affectedKeys().hasAny(['role']) || isAdmin());
      
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /test/connection {
      allow get: if true;
    }

    match /errorLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Backend only
    }

    match /errorReportRuns/{runId} {
      allow read: if isAdmin();
      allow write: if false; // Backend only
    }
  }
}

{
  "entities": {
    "notes": {
      "title": "Note",
      "description": "A geolocated note in the AR world.",
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "maxLength": 1000,
          "description": "The text content of the note (optional if audio is present)."
        },
        "type": {
          "type": "string",
          "enum": ["text", "audio"],
          "description": "The type of the note."
        },
        "audioUrl": {
          "type": "string",
          "description": "The URL of the audio file in Firebase Storage."
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the user who created the note."
        },
        "authorName": {
          "type": "string",
          "description": "The display name of the user who created the note."
        },
        "privacy": {
          "type": "string",
          "enum": ["public", "unlisted", "private"],
          "description": "The privacy level of the note."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was last updated."
        },
        "color": {
          "type": "string",
          "description": "Optional hex color for the note."
        },
        "emoji": {
          "type": "string",
          "description": "Optional emoji for the note pint."
        },
        "language": {
          "type": "string",
          "description": "The language code of the note (e.g., 'en-US', 'es-ES')."
        },
        "moderationState": {
          "type": "string",
          "enum": ["visible", "pending_review", "removed"],
          "description": "The current moderation status of the note. Defaults to visible."
        }
      },
      "required": ["type", "location", "authorId", "createdAt"]
    },
    "users": {
      "title": "User",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "comments": {
      "title": "Comment",
      "description": "A reply or comment on a note.",
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "maxLength": 500,
          "description": "The text content of the comment."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the user who created the comment."
        },
        "authorName": {
          "type": "string",
          "description": "The display name of the user who created the comment."
        },
        "noteId": {
          "type": "string",
          "description": "The ID of the parent note."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the comment was created."
        }
      },
      "required": ["content", "authorId", "authorName", "noteId", "createdAt"]
    },
    "errorLogs": {
      "title": "Error Log",
      "description": "Captured application errors.",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "stack": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] },
        "source": { "type": "string" },
        "route": { "type": "string" },
        "browser": { "type": "string" },
        "userAgent": { "type": "string" },
        "userId": { "type": "string" },
        "appVersion": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "severity", "createdAt"]
    },
    "errorReportRuns": {
      "title": "Error Report Run",
      "description": "History of scheduled error report executions.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["success", "failure"] },
        "errorsCount": { "type": "number" },
        "error": { "type": "string" }
      },
      "required": ["timestamp", "status"]
    },
    "reports": {
      "title": "Note Report",
      "description": "A user-submitted report for a note.",
      "type": "object",
      "properties": {
        "noteId": { "type": "string" },
        "reporterId": { "type": "string" },
        "reason": { "type": "string", "enum": ["spam", "harassment", "hate_speech", "nsfw", "threat", "other"] },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"] }
      },
      "required": ["noteId", "reporterId", "reason", "createdAt", "status"]
    }
  },
  "firestore": {
    "/notes/{noteId}": {
      "schema": "notes",
      "description": "Global collection of geolocated notes."
    },
    "/notes/{noteId}/comments/{commentId}": {
      "schema": "comments",
      "description": "Comments attached to a specific note."
    },
    "/reports/{reportId}": {
      "schema": "reports",
      "description": "Moderation reports submitted by users."
    },
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles restricted to owners."
    },
    "/errorLogs/{logId}": {
      "schema": "errorLogs",
      "description": "Centralized error logs (Backend write only)."
    },
    "/errorReportRuns/{runId}": {
      "schema": "errorReportRuns",
      "description": "History of daily report runs."
    }
  }
}
